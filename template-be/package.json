{
  "name": "template-be",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon -r tsconfig-paths/register ./src/index.ts",
    "codegen": "graphql-codegen --config codegen.yml",
    "package": "rm -rf dist && yarn tsc && yarn bundle && yarn clear",
    "clear": "find dist/* | grep -v 'main' | xargs rm -rf",
    "bundle": "yarn webpack -c webpack.js"
  },
  "dependencies": {
    "@apollo/server": "^4.3.3",
    "@as-integrations/koa": "^0.2.1",
    "@graphql-tools/mock": "^8.7.18",
    "@graphql-tools/schema": "^9.0.16",
    "@koa/cors": "^4.0.0",
    "@koa/multer": "^3.0.2",
    "@koa/router": "^12.0.0",
    "dotenv": "^16.0.3",
    "graphql": "^16.6.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.11.3",
    "jsonwebtoken": "^9.0.0",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.3.0",
    "mongodb": "^5.0.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.1",
    "ws": "^8.12.0"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^4.0.0",
    "@graphql-codegen/cli": "^3.0.0",
    "@graphql-codegen/introspection": "^3.0.0",
    "@graphql-codegen/typescript": "^3.0.0",
    "@graphql-codegen/typescript-resolvers": "^3.0.0",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.10",
    "@types/koa__cors": "^3.3.0",
    "@types/koa__multer": "^2.0.4",
    "@types/koa__router": "^12.0.0",
    "@types/lodash-es": "^4.17.6",
    "@types/node": "^18.13.0",
    "@types/nodemailer": "^6.4.7",
    "@types/ws": "^8.5.4",
    "@typescript-eslint/eslint-plugin": "^5.22.0",
    "@typescript-eslint/parser": "^5.22.0",
    "eslint": "^8.25.0",
    "eslint-plugin-react": "^7.29.4",
    "eslint-plugin-react-hooks": "^4.5.0",
    "nodemon": "^2.0.20",
    "tsconfig-paths": "^3.14.2",
    "typescript": "^4.5.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-node-externals": "^3.0.0"
  },
  "prettier": {
    "trailingComma": "es5",
    "bracketSpacing": false,
    "jsxBracketSameLine": false,
    "singleQuote": true,
    "semi": false
  }
}
